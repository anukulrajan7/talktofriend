# ─────────────────────────────────────────────────────────────
# TalkToFriend Configuration
# Copy this file to `.env` and fill in the values before running.
# Never commit .env to git.
# ─────────────────────────────────────────────────────────────

# ── Server ──────────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# ── Public domain (for Caddy HTTPS via Let's Encrypt) ───────
# Example: talk.example.com
DOMAIN=

# ── CORS (comma-separated additional allowed domains) ───────
# Example: talktofriend.com,talk.example.com
# Localhost and *.talktofriend.com are always allowed.
ALLOWED_ORIGINS=

# ── mediasoup (WebRTC SFU) ──────────────────────────────────
# Public IP of your VPS — REQUIRED in production for WebRTC to work
ANNOUNCED_IP=

# Number of worker processes (defaults to CPU count)
MS_WORKERS=

# RTC port range — must be open in firewall (UDP + TCP)
RTC_MIN_PORT=40000
RTC_MAX_PORT=49999

# ── Room + rate limits ──────────────────────────────────────
MAX_PEOPLE_PER_ROOM=20
MAX_TOTAL_ROOMS=500
MAX_TOTAL_SOCKETS=2000

HTTP_WINDOW_MS=60000
HTTP_MAX_PER_WINDOW=120
WS_MAX_CONN_PER_IP=5
WS_MSG_PER_SEC=100
CHAT_MAX_PER_10S=30
ROOM_CREATE_PER_HOUR=10
CONCURRENT_ROOMS_PER_IP=3

# ── Grafana ─────────────────────────────────────────────────
# Change this BEFORE first boot. Used for Grafana admin login.
GRAFANA_PASSWORD=

# ── Telegram alerts (optional) ──────────────────────────────
# Create bot: message @BotFather on Telegram
# Get chat ID: message @userinfobot on Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
