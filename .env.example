# ─────────────────────────────────────────────────────────────
# TalkToFriend Configuration
# Copy to `.env` and fill in values. Never commit .env to git.
# ─────────────────────────────────────────────────────────────

# ── Server ──────────────────────────────────────────────────
PORT=3000
NODE_ENV=production
LOG_LEVEL=info

# ── Domain (for Caddy HTTPS via Let's Encrypt) ─────────────
DOMAIN=talktofriend.online

# ── CORS (comma-separated additional allowed domains) ───────
# localhost + *.talktofriend.com + *.talktofriend.online always allowed.
ALLOWED_ORIGINS=talktofriend.online

# ── mediasoup (WebRTC SFU) ──────────────────────────────────
# Public IP of your VPS — REQUIRED for WebRTC to work in production.
# Without this, peers cannot connect media streams.
ANNOUNCED_IP=

# Number of worker processes (defaults to CPU count).
# On a small VPS (1-2 cores), set to 1.
MS_WORKERS=1

# RTC port range — must be open in firewall (UDP + TCP).
# Smaller range = fewer firewall rules needed.
RTC_MIN_PORT=40000
RTC_MAX_PORT=40200

# ── Room + rate limits ──────────────────────────────────────
MAX_PEOPLE_PER_ROOM=20
MAX_TOTAL_ROOMS=500
MAX_TOTAL_SOCKETS=2000

HTTP_WINDOW_MS=60000
HTTP_MAX_PER_WINDOW=120
WS_MAX_CONN_PER_IP=5
WS_MSG_PER_SEC=100
CHAT_MAX_PER_10S=30
ROOM_CREATE_PER_HOUR=10
CONCURRENT_ROOMS_PER_IP=3

# ── Grafana ─────────────────────────────────────────────────
GRAFANA_PASSWORD=
GF_ROOT_URL=https://grafana.talktofriend.online

# ── Telegram alerts (optional) ──────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
